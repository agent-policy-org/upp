{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://upp.dev/schema/v1.0/policy.schema.json",
  "title": "Universal Policy Protocol (UPP) Policy v1.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "policy_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9-_.]*$"
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 2
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "ethical_focus": {
      "type": "string",
      "enum": [
        "bias_mitigation",
        "transparency",
        "accountability",
        "privacy_protection",
        "harm_prevention",
        "socioeconomic_impact",
        "sentience_consideration"
      ]
    },
    "ethical_categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "bias_mitigation",
          "transparency",
          "accountability",
          "privacy_protection",
          "harm_prevention",
          "socioeconomic_impact",
          "sentience_consideration"
        ]
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "condition": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 },
          "enforcement": {
            "type": "string",
            "enum": ["block", "warn", "log"]
          },
          "explanation": { "type": "string" },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "required": ["condition", "action", "enforcement"]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "update_source": {
          "type": "string",
          "format": "uri"
        },
        "authority": {
          "type": "string",
          "minLength": 1
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compliance_date": {
          "type": "string",
          "format": "date"
        }
      },
      "required": ["update_source", "compliance_date"]
    }
  },
  "required": [
    "policy_id",
    "jurisdiction",
    "version",
    "ethical_focus",
    "rules",
    "metadata"
  ]
}
